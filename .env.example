# Copy to .env and fill in. The .env file is git-ignored.

# --- Dahua device (NetSDK source) ---
HOST=your-device-host          # device IP / hostname
HOST_PORT=37777                # NetSDK port (often 37777; some setups use 8100)
USERNAME=admin
PASSWORD=your-device-password

# --- RTSP target (MediaMTX) ---
TARGET_HOST=0.0.0.0            # RTSP server bind/advertise host
TARGET_PORT=8554              # single RTSP port: MediaMTX listen + publish + exposed

# --- Optional RTSP authentication ---
# Set BOTH to require credentials to publish AND view the stream.
# Leave unset (or blank) for open access.
TARGET_USERNAME=
TARGET_PASSWORD=

# --- Optional on-demand mode ---
# Set to true to pull each enabled stream from the device only while a viewer is
# connected (MediaMTX runOnDemand), tearing it down ~10s after the last viewer
# leaves. Unset/false = always-on (every enabled stream runs continuously).
ON_DEMAND=
